# 到 https://aistudio.google.com/app/apikey 申请 Gemini API Key
GEMINI_API_KEY=

## 模型（默认统一使用 Gemini 2.5 Pro）
# 统一默认模型
GEMINI_MODEL=gemini-2.5-pro
# 摘要并发数（默认 3，可调范围 1-6）
GEMINI_SUMMARY_CONCURRENCY=3


# 可选：放宽转写安全阈值（可能包含敏感内容的转写场景建议开启）
# 取值 true/false（默认 true）
GEMINI_SAFETY_BLOCK_NONE=true

## 可选：网络代理（yt-dlp / requests 均可读取这些变量）
# 如无需代理，请留空
#HTTP_PROXY=
#HTTPS_PROXY=
#ALL_PROXY=

## 可选：仅给 yt-dlp 设置代理（优先级高于上面的通用代理）
#YT_DLP_PROXY=

# 说明：
# - CLI 会在启动时自动加载当前目录的 .env（若存在）。
# - 请复制本文件为 .env 并按需填写上述变量。

# 关闭自动翻译（Web/服务端）；CLI 可在运行时加 --no-translate
NO_TRANSLATE=1
TRANSCRIBE_CONCURRENCY=6
EDIT_CONCURRENCY=6

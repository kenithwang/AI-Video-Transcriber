###############################################
# AI-Video-Transcriber 环境变量示例（CLI 版） #
###############################################

## 必填（Gemini 云端转写/优化/翻译/摘要）
# 到 https://aistudio.google.com/app/apikey 申请 Gemini API Key
GEMINI_API_KEY=

## 模型（默认统一使用 Gemini 2.5 Pro）
# 统一默认模型
GEMINI_MODEL=gemini-2.5-pro
# 可分别指定（留空则回退到 GEMINI_MODEL）
GEMINI_TRANSCRIBE_MODEL=
GEMINI_OPTIMIZE_MODEL=
GEMINI_TRANSLATE_MODEL=
GEMINI_SUMMARY_MODEL=
GEMINI_EDIT_MODEL=

## 可选：关闭自动翻译（Web/服务端生效；CLI 请用 --no-translate）
# 取值 1/true/yes 开启关闭开关（即“不要翻译”）；0/false 关闭该开关（允许翻译）
NO_TRANSLATE=1

## 可选：并行转写并发度（默认 3；推荐 4–6）
# 根据你的网络/配额情况调整；并发过高可能触发限速
TRANSCRIBE_CONCURRENCY=6

## 可选：Edit Note 详细转录并行度（默认 4；建议 4–6）
EDIT_CONCURRENCY=6

# 可选：放宽转写安全阈值（可能包含敏感内容的转写场景建议开启）
# 取值 true/false（默认 true）
GEMINI_SAFETY_BLOCK_NONE=true

## 可选：网络代理（yt-dlp / requests 均可读取这些变量）
# 如无需代理，请留空
#HTTP_PROXY=
#HTTPS_PROXY=
#ALL_PROXY=

## 可选：仅给 yt-dlp 设置代理（优先级高于上面的通用代理）
#YT_DLP_PROXY=

# 说明：
# - CLI 会在启动时自动加载当前目录的 .env（若存在）。
# - 请复制本文件为 .env 并按需填写上述变量。
